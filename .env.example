# ── Required ───────────────────────────────────────────────────────────────────
# Telegram Bot Token — get it from @BotFather
TELEGRAM_TOKEN=your_telegram_token_here

# Provider: "ollama" (local dev) or "bedrock" (AWS production)
PROVIDER=bedrock

# ── Ollama settings (used when PROVIDER=ollama) ────────────────────────────────
OLLAMA_MODEL=gemma3:4b
OLLAMA_EMBED=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# ── AWS Bedrock settings (used when PROVIDER=bedrock) ──────────────────────────
# AWS credentials — set these or use IAM role on EC2 (recommended)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# LLM model on Bedrock
# Cheapest:  amazon.nova-micro-v1:0      ($0.035 / $0.14 per 1M tokens)
# Balanced:  amazon.nova-lite-v1:0       ($0.06  / $0.24 per 1M tokens)  ← recommended
# Best:      amazon.nova-pro-v1:0        ($0.80  / $3.20 per 1M tokens)
BEDROCK_LLM_MODEL=amazon.nova-lite-v1:0

# Embedding model on Bedrock
# Multilingual (best for non-English video + English questions):
#   cohere.embed-multilingual-v3         ($0.0001 per 1K tokens)  ← recommended
# English only (slightly cheaper):
#   cohere.embed-english-v3              ($0.0001 per 1K tokens)
# Amazon native (no extra model access needed):
#   amazon.titan-embed-text-v2:0         ($0.00011 per 1K tokens)
BEDROCK_EMBED_MODEL=cohere.embed-multilingual-v3

BEDROCK_RERANK_MODEL=cohere.rerank-v3-5:0

# ── Shared settings ────────────────────────────────────────────────────────────
CHROMA_DIR=./chroma_db

# Number of similar chunks to retrieve from the vector store
SIMILARITY_K=4

# ── Chunking settings ──────────────────────────────────────────────────────────
# Strategy: "sentence" (sentence‑aware), "timestamp" (time‑based segments),
#           "semantic" (embeddings + similarity threshold)
# Default: "timestamp"
CHUNK_STRATEGY=timestamp

# Target token size per chunk (used for all strategies)
CHUNK_TOKENS=300

# Overlap tokens between consecutive chunks (used for sentence & timestamp)
OVERLAP_TOKENS=30

# Similarity threshold for merging segments in semantic strategy (0‑1)
# Higher = fewer, more coherent chunks. Default: 0.75
SIMILARITY_THR=0.75

S3_BUCKET=youtube-rag-bot
SQS_REQUEST_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/youtube-rag-transcript-requests
SQS_RESULT_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/youtube-rag-transcript-results
OPENSEARCH_ENDPOINT=123456qwerty.aoss.us-east-1.on.aws