# Telegram Bot Token — отримай у @BotFather
TELEGRAM_TOKEN=your_telegram_token_here

# Ollama налаштування (залиш як є якщо запускаєш локально)
OLLAMA_MODEL=gemma3:4b
OLLAMA_BASE_URL=http://localhost:11434

# Модель для ембедингів (завантаж: ollama pull nomic-embed-text)
EMBED_MODEL=nomic-embed-text

# Папка для збереження векторної бази
CHROMA_DIR=./chroma_db
